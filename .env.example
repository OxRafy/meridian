# ── Wallet ────────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Solana RPC ─────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Multi-Provider LLM Configuration
# Supports OpenRouter, Ollama, vLLM, OpenAI, Anthropic, Google, and any OpenAI-compatible endpoint

# Primary Provider: OpenRouter (default)
OPENROUTER_API_KEY=***

# Backup Provider: Ollama (local LLM)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=your-ollama-model-name

# Backup Provider: vLLM (serverless GPU)
# VLLM_BASE_URL=https://your-vllm-endpoint/v1
# VLLM_API_KEY=your_vllm_api_key

# Legacy: LM Studio (local)
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=***
# LLM_MODEL=your-model-from-lmstudio


# ── API Keys ───────────────────────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here
LPAGENT_API_KEY=your_lpagent_api_key_here

# ── Telegram Notifications (optional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=

# ── Dangerous admin actions (disabled by default) ─────────────────────────────
ALLOW_SELF_UPDATE=false

# ── Misc ───────────────────────────────────────────────────────────────────────
DRY_RUN=false
LOG_LEVEL=info
